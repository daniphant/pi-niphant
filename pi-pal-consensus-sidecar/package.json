{
  "name": "pi-pal-consensus-sidecar",
  "version": "0.1.0",
  "description": "Local HTTP/SSE dashboard sidecar that drives PAL MCP consensus reviews for Pi.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "keywords": [
    "pi",
    "pi-package",
    "extension",
    "pal",
    "mcp",
    "consensus",
    "dashboard"
  ],
  "pi": {
    "extensions": [
      "."
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@sinclair/typebox": "latest",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dashboard:build": "vite build",
    "build": "npm run dashboard:build",
    "check": "npm run typecheck && npm run build"
  }
}
