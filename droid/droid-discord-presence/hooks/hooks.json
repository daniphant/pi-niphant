{
  "description": "Keep Discord Rich Presence updated from Droid lifecycle hooks.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${DROID_PLUGIN_ROOT}/hooks/discord-presence.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
