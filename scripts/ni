#!/usr/bin/env bash
set -euo pipefail

err() { printf 'ni: %s\n' "$*" >&2; }

if ! command -v git >/dev/null 2>&1; then
  err "git is required."
  exit 127
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  err "run ni from inside an existing git repository."
  err "Tip: cd ~/Projects/<repo> && ni"
  exit 2
fi

if ! command -v pi >/dev/null 2>&1; then
  err "Pi executable not found on PATH. Install Pi or add it to PATH, then retry."
  exit 127
fi

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export NIPHANT=1
export NIPHANT_HOME="${NIPHANT_HOME:-$HOME/.niphant}"
export NIPHANT_PROJECT_ROOT="$PROJECT_ROOT"
export NIPHANT_LAUNCHER_ROOT="$REPO_ROOT"

exec pi "$@"
