{
  "name": "pi-niphant",
  "version": "0.1.0",
  "description": "A trunkful of opinionated workflow, diagnostics, browser, consensus, checkpoint, and harness extensions for Pi.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "pi-agent-notify",
    "pi-ask-user",
    "pi-checkpoint",
    "pi-clear",
    "pi-catppuccin-ui",
    "pi-codex-compaction",
    "pi-codex-like-diff",
    "pi-delegated-agents",
    "pi-delegation-guard",
    "pi-diagnostics",
    "pi-discord-presence",
    "pi-github-repo-explorer",
    "pi-hud",
    "pi-markdown-commands",
    "pi-pal-consensus-sidecar",
    "pi-skill-lab",
    "pi-update-prompt",
    "pi-web-e2e-agent",
    "pi-whimsy-status",
    "pi-workflow",
    "pi-web-tools"
  ],
  "scripts": {
    "check": "npm run check:packages && npm run check:skills",
    "check:packages": "npm run check --workspaces --if-present",
    "check:skills": "mkdir -p .eval-results && node eval/scripts/static-contract-check.mjs --fail-on-violations && node eval/scripts/run-skill-eval.mjs --suite smoke --fail-on-failures > .eval-results/smoke.json",
    "eval:skills": "mkdir -p .eval-results && node eval/scripts/run-skill-eval.mjs --suite all --fail-on-failures > .eval-results/skills.json",
    "eval:holdout": "mkdir -p .eval-results && node eval/scripts/run-skill-eval.mjs --suite holdout --fail-on-failures > .eval-results/holdout.json",
    "install:pi": "./scripts/install.sh",
    "list": "node scripts/list-packages.mjs"
  }
}
